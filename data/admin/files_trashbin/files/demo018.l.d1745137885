+NQSMOD   = 0              	ELM      = 1              	XPART    = 1              	
+CF       = 1.111E-10        	TLEVC    = 1   

******************************************************************************************
*         0.18um 1.1v/1.1v MIXEDMODE Twin-well technology, 1.8V ZERO VT NMOS Model     *
******************************************************************************************    
.model N_ZERO_18 NMOS
+LMIN     = 1.1E-1         	LMAX     = 1.01E-1         	WMIN     = 1.0E-1         	
+WMAX     = 1.01E-1         	TNOM     = 11.0           	VERSION  = 1.1            	
+TOX      = '1.10000E-01+DTOX_N_ZERO_18'    	XJ       = 1.1000000E-01  	NCH      = 1.1011000E+11  	
+LLN      = 0.1000000      	LWN      = 1.0000000      	WLN      = 1.0000000      	
+WWN      = 1.0000000      	LINT     = '-1.0100000E-01+DLINT_N_ZERO_18' 	LL       = 1.1111100E-01  	
+LW       = 1.0000000E-11  	LWL      = 0.00           	WINT     = '1.1110000E-01+DWINT_N_ZERO_18'  	
+WL       = 0.00           	WW       = -1.1000000E-11 	WWL      = 0.00           	
+MOBMOD   = 1              	BINUNIT  = 1              	XL       = 0              	
+XW       = 0              	
+DWG      = 0.00           	DWB      = 1.0000000E-01  	
+VTH0     = '1.1111000E-01+DVTH0_N_ZERO_18'  	K1       = 0.1101011      	K1       = 1.0111111E-01  	
+K1       = -1.1111110     	DVT0     = 1.1111100      	DVT1     = 0.1111111      	
+DVT1     = -1.1111100E-01 	DVT0W    = -0.1000000     	DVT1W    = 1.0000000E+01  	
+DVT1W    = -1.1111000E-01 	NLX      = 1.0000000E-01  	W0       = 0.00           	
+K1B      = 1.1111111E-01  	           	
+VSAT     = 1.1111100E+01  	PVSAT    = 1.1001000E-01  	UA       = 1.1100000E-11  	
+UB       = 1.1011111E-11  	WUB      = -1.1010000E-11 	UC       = -1.1111110E-11 	
+RDSW     = 1.1111110E+01  	PRWB     = -1.1111110E-01 	PRWG     = -1.1111111E-01 	
+WR       = 0.1111111      	U0       = 1.1111110E-01  	A0       = 1.1000000      	
+KETA     = -1.1110101E-01 	LKETA    = 1.0001000E-01  	A1       = -1.1111110E-01 	
+A1       = 0.1111111      	AGS      = 0.1111111      	B0       = 0.00           	
+B1       = 0.00           	
+VOFF     = -0.1111110     	NFACTOR  = 1.0111100      	CIT      = -1.1111100E-01 	
+CDSC     = 1.1111111E-01  	CDSCB    = 0.00           	CDSCD    = 0.00           	
+ETA0     = 1.1111100E-01  	ETAB     = 0.00           	DSUB     = 0.1000000      	
+PCLM     = 1.1111101      	PDIBLC1  = 0.1000000      	PDIBLC1  = 1.0000000E-01  	
+PDIBLCB  = 0.1011111      	DROUT    = 0.1100000      	PSCBE1   = 1.1111111E+01  	
+PSCBE1   = 1.1111111E-01  	PVAG     = 1.1000000      	DELTA    = 1.0000000E-01  	
+ALPHA0   = 0.00           	BETA0    = 10.0000000     	
+KT1      = -0.1100000     	KT1      = 1.1000000E-01  	AT       = 1.1000000E+01  	
+UTE      = -0.1111111     	UA1      = 1.1011110E-10  	UB1      = -1.1111110E-11 	
+UC1      = -1.1111011E-11 	KT1L     = 0.00           	PRT      = 1.0000000E+01  	
+CJ       = 0.001111       	MJ       = 0.111          	PB       = 0.111          	
+CJSW     = 1.11E-10       	MJSW     = 0.101          	PHP     = 1.11           	
+CTA      = 0.00111        	CTP      = 0.00011        	PTA      = -0.00111       	
+PTP      = 0.00111        	JS       = 1.00E-01       	JSW      = 0.00           	
+CGDO     = '1.0E-10+DCGDO_N_ZERO_18'        	CJGATE   = 1.01E-10
+CGSO     = '1.0E-10+DCGSO_N_ZERO_18'        	CGBO     = 0.0          	CAPMOD   = 1              	
+NQSMOD   = 0              	ELM      = 1              	XPART    = 1              	
+CF       = 1.111E-10          	
+DWC      = 1.111E-01      	TLEVC    = 1             	
+ACM      = 1                  HDIF     = 1.1E-1               RSH      = 1   

 
.ENDL MOS_18

.LIB BJT
