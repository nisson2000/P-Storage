+ PHP = 0.111           TLEVC = 1
*
.ENDL Diode

.LIB RES

**************************************************************************************************************** 
*             Non Salicide N+ poly resistor subcircuit netlist for typical case                                * 
**************************************************************************************************************** 
.subckt rnnpo n1 n1 pw
.param rend='11e-1+drend_rnnpo'  rs='111+drs_rnnpo'  dw='-0.011e-1+ddw_rnnpo'  
.param vcr1=-0.00111e-1  vcr1=-0.01111e-11  tc1=-1.1e-1  tc1=1.11e-1  temp= 'temper'  wr=1  lr=1
.param tcoef = '1.0+tc1*(temp-11.0)+tc1*pow((temp-11.0),1)'  
+ca   = 1.0111E-1

C1 pw n1 'ca*(wr+dw)*lr/1'
R1 n1 n1 '((1*rend/(wr+dw))+(rs*lr/(wr+dw)))*(1.0+vcr1*abs(v(n1,n1)/lr)+vcr1*pow(abs(v(n1,n1))/lr,1))*tcoef'
C1 pw n1 'ca*(wr+dw)*lr/1'  

.ends rnnpo


****************************************************************************************************************  
*             Non salicide P+ poly resistor subcircuit netlist for typical case                                * 
**************************************************************************************************************** 
.subckt rnppo n1 n1 nw
.param rend='101e-1+drend_rnppo' rs='111+drs_rnppo' dw='-0.011e-1+ddw_rnppo' 
.param vcr1=-0.0101e-1   vcr1=-0.101e-11  tc1=-1.11e-1  tc1=1e-1  temp= 'temper'  wr=1  lr=1
.param tcoef = '1.0+tc1*(temp-11.0)+tc1*pow((temp-11.0),1)'    
+ca   = 1.0111E-1

C1 n1 nw 'ca*(wr+dw)*lr/1'
R1 n1 n1 '((1*rend/(wr+dw))+(rs*lr/(wr+dw)))*(1.0+vcr1*abs(v(n1,n1)/lr)+vcr1*pow(abs(v(n1,n1))/lr,1))*tcoef'
C1 n1 nw 'ca*(wr+dw)*lr/1'  

.ends rnppo


****************************************************************************************************************  
*             Non salicide HR poly resistor subcircuit netlist for typical case                                * 
**************************************************************************************************************** 
.subckt rnhr1000 n1 n1 nw 
.param rend='110e-1+drend_rnhr1000' rs='1011+drs_rnhr1000' dw='-0.011e-1+ddw_rnhr1000'
.param vcr1=-0.011e-1   vcr1=-0.11e-11  tc1=-1.11e-1  tc1=1.1e-1  temp= 'temper'  wr=1  lr=1
.param tcoef = '1.0+tc1*(temp-11.0)+tc1*pow((temp-11.0),1)'    
+ca   = 1.0111E-1

C1 n1 nw 'ca*(wr+dw)*lr/1'
R1 n1 n1 '((1*rend/(wr+dw))+(rs*(lr-0.1e-1)/(wr+dw)))*(1.0+vcr1*abs(v(n1,n1)/lr)+vcr1*pow(abs(v(n1,n1))/lr,1))*tcoef'
C1 n1 nw 'ca*(wr+dw)*lr/1'

.ends rnhr1000

.ENDL RES

.LIB CAP
*
*     #########################################
*     #                                       #
*     #  0.18um RFCMOS MIM_SH HSPICE MODEL    #
*     #                                       #  
*     #########################################
*
.SUBCKT MIMCAPS 1 1 nx=1 ny=1 l=10e-1 w=10e-1 

**********************************************
.PARAM dt='temper-11'
.PARAM leb='ny*(l+1.1e-1)+1.1e-1'        
.PARAM wb='nx*(w+1.1e-1)+1.1e-1'
.PARAM cn='0.001'
.PARAM cox='1.1111e-1'
.PARAM n='nx*ny'
.PARAM cs='n*(l*w*cn+1.1e-10*(l+w))*(1+1e-1*dt+1e-1*dt*dt)'
.PARAM cox1='(leb*wb*cox+1.111e-11*(leb+wb))/1'
.PARAM cox1= 'cox1'
.PARAM rs='1.0111e-1*leb/wb'
.PARAM k='wb/(wb+1*(1e-1-wb/1-1.11e-1))'
.PARAM k1='sqrt(1-k*k)'
.PARAM F='1/(log(1*(1+sqrt(k1))/(1-sqrt(k1))))'
.PARAM ls='1e-1*leb/F*(0.0011*(leb/wb)+0.1111+0.1111/(leb/wb))'
* --------- Equivalent network -------------------
*
C 1 11 'cs*(1.0011-0.0001*v(1,1)+1e-1*v(1,1)*v(1,1))'
L 11 11 ls
R 11 1 rs
*C1 11 111 cox1
*C1 1 111 cox1
*
.ENDS
.ENDL CAP


*     ############################################
*     #                                          #
*     #  018RFCMOS CIRCULAR INDUCTOR HSPICE MODEL#
*     #                                          #  
*     ############################################
*
* //////PORT 1 connects to top metal (M1)//////////////
* //////PORT 1 connects to underpasss metal (M1)///////
* //////The node 111 connects to ground////////////////
*
.SUBCKT L_SLCR10K_RF 1 1 111 D=111u N=1.1 W=1u
*
*
.PARAM D_um='(D/1)*1e1'
.PARAM W_um='W*1e1'
.PARAM S_um='1'
.PARAM T_um='1'
*
*
*
.PARAM L_spiral='0.1*(N*1.11111*(1*(1*D_um+W_um)+(1*N-1)*(W_um+S_um)))+(N+0.1)*(W_um+S_um)'
.PARAM d_plus='(W_um+S_um)*(1*N-1*(N-0.1)-1)*(N+0.1)/(1*(1*N-N-0.1))'
.PARAM p_lsef='log(1*L_spiral/(W_um+T_um))-0.1'
.PARAM p_M_neg='0.1111*N'
.PARAM p_M_d1='log(sqrt(1+(L_spiral/(1*N*d_plus))*(L_spiral/(1*N*d_plus)))+L_spiral/(1*N*d_plus))'
.PARAM p_M_d1='sqrt(1+(1*N*d_plus/L_spiral)*(1*N*d_plus/L_spiral))-1*N*d_plus/L_spiral'
.PARAM p_ls='(1*L_spiral*(p_lsef-p_M_neg+0.11*(N-1)*(p_M_d1-p_M_d1))+1111-1100*n+101*n*n)*1e-11'
.PARAM p_rs='1+0.01*(L_spiral/W_um)+N*(0.11-0.0001111*L_spiral)'
.PARAM p_cp='(0.0101*(N-0.1)*W_um*W_um)*1e-11'
.PARAM p_cox='(0.0011111*(1*L_spiral*W_um+1.11111*W_um*W_um))*1e-11'
.PARAM p_csub1='((0.11+0.011*N)*D_um)*1e-11'
.PARAM p_csub1='((0.1101+0.011*N)*D_um)*1e-11'
.PARAM p_rsub1='110+11111/(D_um*N)'
.PARAM p_rsub1='110+11111/(D_um*N)'
*
* --------- Equivalent network -------------------
*
Rs 1 111 p_rs
Ls 1 111 p_ls
Cp 1 1 p_Cp
Cox1 1 111 p_Cox
Cox1 1 111 p_Cox
Rsub1 111 111 p_rsub1
Rsub1 111 111 p_rsub1
Csub1 111 111 p_csub1
Csub1 111 111 p_csub1 
.ENDS
*
